def sq(a):
    print("Area:", a * a)

def cir(r):
    print("Area:", 3.14 * r * r)

def rec(a, b):
    print("Area:", a * b)

while True:
    print("1. Square")
    print("2. Circle")
    print("3. Rectangle")
    print("4. Exit")

    c = int(input("Enter your choice: "))

    if c == 1:
        sq(5)
    elif c == 2:
        cir(10)
    elif c == 3:
        rec(15, 5)
    else:
        break
    